{
  "app-id": "{{.AppID}}",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk//25.08",
  "command": "{{.Command}}",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "name": "{{.Name}}",
      "buildsystem": "simple",
      "build-commands": [
        "install -D {{.Command}} /app/bin/{{.Command}}",
        "install -D {{.AppID}}.desktop /app/share/applications/{{.AppID}}.desktop",
        "install -D {{.AppID}}.metainfo.xml /app/share/metainfo/{{.AppID}}.metainfo.xml",
        "install -D icons/icon-16.png /app/share/icons/hicolor/16x16/apps/{{.AppID}}.png",
        "install -D icons/icon-32.png /app/share/icons/hicolor/32x32/apps/{{.AppID}}.png",
        "install -D icons/icon-64.png /app/share/icons/hicolor/64x64/apps/{{.AppID}}.png",
        "install -D icons/icon-128.png /app/share/icons/hicolor/128x128/apps/{{.AppID}}.png",
        "install -D icons/icon-256.png /app/share/icons/hicolor/256x256/apps/{{.AppID}}.png",
        "install -D icons/icon-512.png /app/share/icons/hicolor/512x512/apps/{{.AppID}}.png"
      ],
      "sources": [
        { "type": "file","path": "../{{.Command}}"},
        { "type": "file", "path": "{{.AppID}}.desktop" },
        { "type": "file", "path": "{{.AppID}}.metainfo.xml" },
        { "type": "file", "path": "icons/icon-16.png" },
        { "type": "file", "path": "icons/icon-32.png" },
        { "type": "file", "path": "icons/icon-64.png" },
        { "type": "file", "path": "icons/icon-128.png" },
        { "type": "file", "path": "icons/icon-256.png" },
        { "type": "file", "path": "icons/icon-512.png" }
      ]
    }
  ]
}
